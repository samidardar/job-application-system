# Database
POSTGRES_PASSWORD=postulio_dev_password
DATABASE_URL=postgresql+asyncpg://postulio:postulio_dev_password@postgres:5432/postulio

# Redis
REDIS_URL=redis://redis:6379/0

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MINIMUM 32 characters required or the app will refuse to start
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Anthropic — Claude Haiku 4.5 (cheapest model, ~$0.08/MTok input / $0.25/MTok output)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Daily token budget across all users (5M ≈ $1.25/day). Increase as needed.
CLAUDE_DAILY_TOKEN_LIMIT=5000000

# France Travail API (ex Pôle Emploi) — https://francetravail.io/data/api
# Créer une application sur https://francetravail.io pour obtenir ces clés
FRANCE_TRAVAIL_CLIENT_ID=your-client-id
FRANCE_TRAVAIL_CLIENT_SECRET=your-client-secret

# Email (for follow-ups) - optional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password

# Storage
STORAGE_PATH=/app/storage

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend — set to your actual API domain in production
# This is embedded in the Next.js client bundle at build time
NEXT_PUBLIC_API_URL=http://localhost:8000

# PRODUCTION CHECKLIST:
# 1. SECRET_KEY — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# 2. POSTGRES_PASSWORD — use a strong random password
# 3. ANTHROPIC_API_KEY — from console.anthropic.com
# 4. NEXT_PUBLIC_API_URL — set to your real API domain (https://api.yourdomain.com)
# 5. ENVIRONMENT=production
# 6. Never commit this file with real values
